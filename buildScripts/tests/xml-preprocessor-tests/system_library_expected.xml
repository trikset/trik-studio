<constraints>
    <timelimit value="10000"/>
    <init>
        <setter _1="2" name="sumVariable"/>
    </init>
    <event id="" settedUpInitially="true">
        <condition>
            <timer forceDropOnTimeout="false" timeout="5000"/>
        </condition>
        <triggers>
            <success/>
        </triggers>
    </event>
    <event id="" settedUpInitially="true">
        <condition>
            <timer forceDropOnTimeout="false" timeout="10000"/>
        </condition>
        <triggers>
            <setUp id="mock_id"/>
            <success/>
        </triggers>
    </event>
    <event id="" settedUpInitially="true">
        <conditions glue="and">
            <not>
                <inside objectId="skittle" objectPoint="any" regionId="zone1"/>
            </not>
        </conditions>
        <triggers>
            <message text="Object skittle not inside zone"/>
            <success/>
        </triggers>
    </event>
    <event id="id_1" settedUpInitially="false">
        <conditions glue="and">
            <not>
                <inside objectId="object" objectPoint="any" regionId="zone1"/>
            </not>
        </conditions>
        <triggers>
            <setter name="score">
                <sum _1="${score}" _2="${sumVariable}"/>
            </setter>
            <message text="Points scored: ${score}"/>
        </triggers>
    </event>
    <event id="id_2" settedUpInitially="true">
        <conditions glue="and">
            <condition>
                <inside objectId="object" objectPoint="any" regionId="zone1"/>
            </condition>
        </conditions>
        <triggers>
            <setter name="score">
                <sum _1="${score}" _2="${sumVariable}"/>
            </setter>
            <message text="Points scored: ${score}"/>
        </triggers>
    </event>
</constraints>